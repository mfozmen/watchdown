{
  "name": "watchdown",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-platform desktop markdown editor with live external-edit sync.",
  "license": "MIT",
  "author": "mfozmen",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build:app": "electron-vite build",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "cert:win": "powershell -ExecutionPolicy Bypass -File scripts/make-selfsigned-cert.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.20.0",
    "@vitest/coverage-v8": "^3.2.4",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.6",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.3",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.11",
    "markdown-it": "^14.3.0",
    "node-diff3": "^3.2.1"
  }
}
